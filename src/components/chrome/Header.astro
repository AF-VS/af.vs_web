---
import type { Dict } from '../../i18n/en';
import { switchLocaleUrl, locales, localeLabels, type Locale } from '../../lib/paths';

interface Props {
  dict: Dict;
  locale: Locale;
}

const { dict, locale } = Astro.props;
const otherLocales = locales.filter((l) => l !== locale);
---

<header class="header" data-header>
  <nav class="header__inner">
    <!-- Brand -->
    <a class="brand" href={locale === 'en' ? '/' : `/${locale}/`} aria-label="AF Venture Studio — home">
      AF VENTURE STUDIO
    </a>

    <!-- Center nav links (desktop) -->
    <div class="nav-center">
      <a class="nav-link" href="#services">{dict.nav.services}</a>
      <a class="nav-link" href="#cases">{dict.nav.cases}</a>
      <a class="nav-link" href="#contact">{dict.nav.bref}</a>
    </div>

    <!-- Right group -->
    <div class="header__right">
      <div class="lang-dropdown" data-lang-dropdown>
        <button class="lang-trigger" type="button" aria-expanded="false" aria-haspopup="true">
          {localeLabels[locale]}
          <svg class="lang-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 4.5 6 7.5 9 4.5" />
          </svg>
        </button>
        <div class="lang-menu">
          {otherLocales.map((loc) => (
            <a class="lang-option" href={switchLocaleUrl(Astro.url.pathname, loc)}>
              {localeLabels[loc]}
            </a>
          ))}
        </div>
      </div>

      <button
        class="burger"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle menu"
        data-burger
      >
        <svg
          class="burger__icon"
          viewBox="0 0 32 32"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            class="burger__path"
            d="M27 10 13 10C10.8 10 9 8.2 9 6 9 3.5 10.8 2 13 2 15.2 2 17 3.8 17 6L17 26C17 28.2 18.8 30 21 30 23.2 30 25 28.2 25 26 25 23.8 23.2 22 21 22L7 22"
          />
          <path d="M7 16 27 16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile overlay menu -->
  <div class="mobile-menu" id="mobile-menu" data-mobile-menu>
    <div class="mobile-menu__content">
      <div class="mobile-menu__links">
        <a href="#services" data-mobile-link>{dict.nav.services}</a>
        <a href="#cases" data-mobile-link>{dict.nav.cases}</a>
        <a href="#contact" data-mobile-link>{dict.nav.bref}</a>
      </div>
      <div class="mobile-menu__bottom">
        <div class="lang-row">
          {locales.map((loc) => loc === locale ? (
            <span class="lang-row__item lang-row__item--active" aria-current="true">
              {localeLabels[loc]}
            </span>
          ) : (
            <a class="lang-row__item" href={switchLocaleUrl(Astro.url.pathname, loc)}>
              {localeLabels[loc]}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('[data-header]') as HTMLElement;
  const burger = document.querySelector('[data-burger]') as HTMLButtonElement;
  const menu = document.querySelector('[data-mobile-menu]') as HTMLElement;
  const mobileLinks = document.querySelectorAll('[data-mobile-link]');

  let open = false;

  function onScroll() {
    header.classList.toggle('header--scrolled', window.scrollY > 10);
  }

  function toggleMenu() {
    open = !open;
    header.classList.toggle('header--open', open);
    burger.setAttribute('aria-expanded', String(open));
    menu.classList.toggle('mobile-menu--open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  }

  function closeMenu() {
    if (!open) return;
    open = false;
    header.classList.remove('header--open');
    burger.setAttribute('aria-expanded', 'false');
    menu.classList.remove('mobile-menu--open');
    document.body.style.overflow = '';
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  burger.addEventListener('click', toggleMenu);
  mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));

  // Language dropdown
  const langDropdown = document.querySelector('[data-lang-dropdown]');
  if (langDropdown) {
    const trigger = langDropdown.querySelector('.lang-trigger') as HTMLButtonElement;
    const langMenu = langDropdown.querySelector('.lang-menu') as HTMLElement;

    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', String(!expanded));
      langMenu.classList.toggle('lang-menu--open');
    });

    document.addEventListener('click', (e) => {
      if (!langDropdown.contains(e.target as Node)) {
        trigger.setAttribute('aria-expanded', 'false');
        langMenu.classList.remove('lang-menu--open');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        trigger.setAttribute('aria-expanded', 'false');
        langMenu.classList.remove('lang-menu--open');
      }
    });
  }
</script>

<style>
  /* ── Header shell ──────────────────────────── */
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    transition: background-color 0.4s ease, border-color 0.4s ease;
  }

  .header--scrolled {
    background-color: rgba(6, 11, 20, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .header--open {
    background-color: rgba(6, 11, 20, 0.95);
  }

  /* ── Inner layout — 3-col grid ─────────────── */
  .header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    height: var(--header-height);
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--container-padding-mobile);
  }

  @media (min-width: 768px) {
    .header__inner {
      padding-inline: var(--container-padding-laptop);
    }
  }

  @media (min-width: 1248px) {
    .header__inner {
      padding-inline: var(--container-padding-desktop);
    }
  }

  /* ── Brand ─────────────────────────────────── */
  .brand {
    justify-self: start;
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--text-primary);
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .brand:hover {
    opacity: 0.7;
  }

  /* ── Center nav ────────────────────────────── */
  .nav-center {
    display: none;
    align-items: center;
    gap: 32px;
    justify-self: center;
  }

  .nav-link {
    color: var(--text-subtle);
    font-size: var(--font-size-caption);
    font-weight: 400;
    padding: 8px 0;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  /* ── Right group ───────────────────────────── */
  .header__right {
    display: flex;
    align-items: center;
    justify-self: end;
    gap: 12px;
  }

  /* ── Language dropdown ─────────────────────── */
  .lang-dropdown {
    position: relative;
    display: none;
  }

  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    font-weight: 400;
    padding: 8px 4px;
    transition: color 0.2s ease;
    cursor: pointer;
  }

  .lang-trigger:hover {
    color: var(--text-primary);
  }

  .lang-chevron {
    transition: transform 0.2s ease;
  }

  .lang-trigger[aria-expanded='true'] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    min-width: 64px;
    background: rgba(6, 11, 20, 0.95);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 4px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, visibility 0.15s ease, transform 0.15s ease;
  }

  .lang-menu--open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .lang-option {
    display: block;
    padding: 8px 12px;
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    border-radius: 8px;
    transition: color 0.15s ease, background 0.15s ease;
    text-align: center;
  }

  .lang-option:hover {
    color: var(--text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  /* ── Burger button ─────────────────────────── */
  .burger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    color: var(--text-primary);
    transition: opacity 0.2s ease;
  }

  .burger:hover {
    opacity: 0.7;
  }

  .burger__icon {
    width: 22px;
    height: 22px;
    transition: transform 0.3s ease;
  }

  .header--open .burger__icon {
    transform: rotate(-45deg);
  }

  .burger__path {
    stroke-dasharray: 12 63;
    transition: stroke-dasharray 0.3s ease, stroke-dashoffset 0.3s ease;
  }

  .header--open .burger__path {
    stroke-dasharray: 20 300;
    stroke-dashoffset: -32.42px;
  }

  /* ── Mobile menu ───────────────────────────── */
  .mobile-menu {
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 40;
    background-color: rgba(6, 11, 20, 0.95);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .mobile-menu--open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu__content {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding: 32px var(--container-padding-mobile);
    transform: translateY(8px);
    opacity: 0;
    transition: transform 0.35s ease 0.05s, opacity 0.3s ease 0.05s;
  }

  .mobile-menu--open .mobile-menu__content {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-menu__links {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-menu__links a {
    display: block;
    padding: 16px 8px;
    font-family: var(--font-display);
    font-size: var(--font-size-h4);
    font-weight: 700;
    line-height: var(--line-height-h4);
    letter-spacing: var(--letter-spacing-h4);
    color: var(--text-primary);
    border-radius: 12px;
    transition: color 0.2s ease;
  }

  .mobile-menu__links a:hover {
    color: var(--primary-accent);
  }

  .mobile-menu__bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-bottom: 32px;
  }

  /* ── Mobile language row ───────────────────── */
  .lang-row {
    display: flex;
    gap: 16px;
    padding: 8px 0;
  }

  .lang-row__item {
    font-size: var(--font-size-body);
    color: var(--text-secondary);
    padding: 8px 0;
    transition: color 0.2s ease;
  }

  .lang-row__item:hover {
    color: var(--text-primary);
  }

  .lang-row__item--active {
    color: var(--text-primary);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  /* ── Desktop breakpoint ────────────────────── */
  @media (min-width: 768px) {
    .nav-center {
      display: flex;
    }

    .lang-dropdown {
      display: block;
    }

    .burger {
      display: none;
    }

    .mobile-menu {
      display: none;
    }
  }
</style>
