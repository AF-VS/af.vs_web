---
import s from "./Header.module.css";
import SymbolWhite from "../../../assets/brand/symbol_white.svg";
import type { Dict } from "../../../i18n/en";
import type { Locale } from "../../../i18n";
import { switchLocaleUrl } from "../../../lib/paths";

interface Props {
  dict: Dict;
  locale: Locale;
}

const { dict, locale } = Astro.props;

const localeHref = (target: Locale): string => switchLocaleUrl(Astro.url.pathname, target);

const languages: readonly Locale[] = ["en", "ru", "uz"];
---

<header class={s.nav}>
  <a class={s.logo} href={localeHref(locale)} aria-label="AFVS home">
    <SymbolWhite class={s.mark} />
    <span>AF Venture Studio</span>
  </a>
  <nav class={s.mid} aria-label="Primary">
    <a href="#services">{dict.nav.services}</a>
    <a href="#cases">{dict.nav.cases}</a>
    <a href="#contact">{dict.nav.brif}</a>
  </nav>
  <div class={s.right}>
    <details class={s.lang} data-lang-dropdown>
      <summary class={s.langSummary} aria-label="Change language">
        <span>{locale.toUpperCase()}</span>
        <svg class={s.chev} width="10" height="10" viewBox="0 0 10 10" aria-hidden="true">
          <path d="M2 3.5L5 6.5L8 3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </summary>
      <ul class={s.langMenu} role="menu">
        {
          languages
            .filter((l) => l !== locale)
            .map((l) => (
              <li role="none">
                <a role="menuitem" href={localeHref(l)} hreflang={l} data-astro-prefetch>
                  {l.toUpperCase()}
                </a>
              </li>
            ))
        }
      </ul>
    </details>
    <button class={s.burger} data-burger aria-label="Open menu" type="button"
      ><span></span></button
    >
  </div>
</header>

<script>
  const dd = document.querySelector<HTMLDetailsElement>("[data-lang-dropdown]");
  if (dd) {
    document.addEventListener("click", (e) => {
      if (!dd.open) return;
      if (!dd.contains(e.target as Node)) dd.open = false;
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && dd.open) {
        dd.open = false;
        (dd.querySelector("summary") as HTMLElement)?.focus();
      }
    });
  }
</script>
