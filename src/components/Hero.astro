---
// Hero.astro component
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<style>
  @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=Instrument+Serif:ital@0;1&display=swap');
  
  .font-instrument-sans {
    font-family: 'Instrument Sans', sans-serif;
  }
</style>

<section id="hero" class="relative w-full min-h-screen bg-black text-white overflow-hidden snap-start snap-always">
  <!-- Background Video Layer -->
  <video
    id="hero-video"
    muted
    loop
    playsinline
    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-[2000ms] ease-in-out"
  ></video>

  <!-- Video Overlay -->
  <div class="absolute inset-0 bg-black/60 backdrop-blur-[2px]"></div>

  <!-- Decorative Gradients -->
  <div class="absolute top-0 left-0 w-full h-[500px] bg-gradient-to-br from-blue-900/40 via-transparent to-transparent blur-[100px] mix-blend-screen pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-full h-[500px] bg-gradient-to-tl from-indigo-900/40 via-transparent to-transparent blur-[100px] mix-blend-screen pointer-events-none"></div>

  <!-- Smooth Bottom Fade into next section -->
  <div class="absolute bottom-0 left-0 w-full h-48 sm:h-64 bg-gradient-to-t from-black via-black/80 to-transparent z-10 pointer-events-none"></div>

  <!-- Content Container -->
  <div class="relative z-10 w-full min-h-screen flex flex-col justify-center items-center px-4 max-w-[1200px] mx-auto space-y-12 text-center">
    
    <!-- Main Headline -->
    <h1 class="hero-headline opacity-0 font-instrument-sans font-semibold text-5xl sm:text-7xl lg:text-[96px] leading-[1.0] tracking-tighter bg-gradient-to-b from-white via-white to-[#b4c0ff] bg-clip-text text-transparent origin-center">
      {t('hero.title')}
    </h1>

    <!-- Subheadline -->
    <p class="hero-subheadline opacity-0 font-instrument-sans text-lg sm:text-[20px] leading-[1.65] text-white/70 max-w-xl mx-auto">
      {t('hero.subtitle')}
    </p>

    <!-- CTA Button -->
    <div class="hero-button opacity-0 flex w-full justify-center">
      <button class="flex items-center gap-4 pl-6 pr-2 py-2 rounded-full bg-white group transition-all">
        <span class="font-instrument-sans font-medium text-lg text-[#0a0400]">{t('hero.cta')}</span>
        <div class="w-[40px] h-[40px] rounded-full bg-[#3054ff] group-hover:bg-[#2040e0] flex items-center justify-center shrink-0 transition-all duration-300 group-hover:shadow-[0_0_20px_rgba(255,255,255,0.3)] group-hover:scale-105">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white lucide lucide-arrow-down"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        </div>
      </button>
    </div>

  </div>
</section>

