---
// Calculator.astro component
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<style>
  .font-instrument-sans {
    font-family: 'Instrument Sans', sans-serif;
  }
  
  /* Pill-shaped toggles for Glassmorphism */
  .calc-btn {
      padding: 0.75rem 1.5rem;
      border-radius: 9999px; /* full pill */
      border: 1px solid rgba(255, 255, 255, 0.08);
      background-color: rgba(255, 255, 255, 0.03);
      color: rgba(255, 255, 255, 0.6);
      font-size: 0.875rem;
      font-weight: 500;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      text-align: center;
      cursor: pointer;
  }
  .calc-btn:hover {
      background-color: rgba(255, 255, 255, 0.1);
      color: rgb(255, 255, 255);
  }
  .calc-btn.active {
      background-color: #3054ff; /* Hero button blue */
      border-color: rgba(48, 84, 255, 0.8);
      color: white;
      box-shadow: 0 0 24px rgba(48, 84, 255, 0.5); /* Neon glow */
  }

  /* Thin elegant neon slider */
  input[type=range] {
      -webkit-appearance: none;
      width: 100%;
      height: 4px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 9999px;
      outline: none;
  }
  input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: #ffffff;
      cursor: pointer;
      box-shadow: 0 0 16px rgba(48, 84, 255, 0.8), inset 0 0 4px rgba(0,0,0,0.2);
      border: 2px solid #3054ff;
      transition: transform 0.2s;
  }
  input[type=range]::-webkit-slider-thumb:hover {
      transform: scale(1.2);
  }
  input[type=range]::-moz-range-thumb {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: #ffffff;
      cursor: pointer;
      box-shadow: 0 0 16px rgba(48, 84, 255, 0.8), inset 0 0 4px rgba(0,0,0,0.2);
      border: 2px solid #3054ff;
      transition: transform 0.2s;
  }
  input[type=range]::-moz-range-thumb:hover {
      transform: scale(1.2);
  }
</style>

<section id="calculator" class="relative w-full min-h-screen bg-black text-white flex items-center justify-center font-instrument-sans px-4 py-20 overflow-hidden snap-start snap-always">
  
  <!-- Animated Neon Background Orbs (Colors from Hero) -->
  <div id="orb-1" class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-[#3054ff]/40 rounded-full blur-[120px] pointer-events-none mix-blend-screen opacity-60"></div>
  <div id="orb-2" class="absolute bottom-1/4 right-1/4 w-[500px] h-[500px] bg-[#b4c0ff]/30 rounded-full blur-[140px] pointer-events-none mix-blend-screen opacity-60"></div>
  <div id="orb-3" class="absolute top-1/2 left-1/2 w-[300px] h-[300px] bg-indigo-900/50 rounded-full blur-[100px] pointer-events-none mix-blend-screen"></div>

  <!-- Main Glassmorphic Container -->
  <div class="relative z-10 w-full max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-semibold mb-4 bg-gradient-to-b from-white via-white to-[#b4c0ff] bg-clip-text text-transparent tracking-tighter">
        {t('calc.title')}
      </h2>
      <p class="text-white/60 text-lg sm:text-xl max-w-2xl mx-auto">{t('calc.subtitle')}</p>
    </div>

    <!-- Hidden data for JavaScript access -->
    <div id="calc-data" data-month={t('calc.month')} data-months={t('calc.months')} data-dev={t('calc.dev')} data-devs={t('calc.devs')} class="hidden"></div>
    <div class="bg-white/[0.02] border border-white/[0.08] backdrop-blur-[40px] shadow-[0_8px_32px_rgba(0,0,0,0.5)] rounded-[32px] overflow-hidden flex flex-col lg:flex-row">
      <!-- Left: Inputs Section -->
      <div class="flex-1 p-8 sm:p-12 space-y-12">
        
        <!-- Category -->
        <div class="space-y-5">
          <label class="block text-sm font-medium text-white/50 uppercase tracking-widest pl-1">{t('calc.category')}</label>
          <div class="flex flex-wrap gap-3" id="calc-category">
            <button type="button" class="calc-btn active" data-value="landing">{t('calc.cat.landing')}</button>
            <button type="button" class="calc-btn" data-value="ecommerce">{t('calc.cat.ecommerce')}</button>
            <button type="button" class="calc-btn" data-value="saas">{t('calc.cat.saas')}</button>
            <button type="button" class="calc-btn" data-value="mobile">{t('calc.cat.mobile')}</button>
          </div>
        </div>

        <!-- Platform -->
        <div class="space-y-5">
          <label class="block text-sm font-medium text-white/50 uppercase tracking-widest pl-1">{t('calc.platform')}</label>
          <div class="flex flex-wrap gap-3" id="calc-platform">
            <button type="button" class="calc-btn active" data-value="web">{t('calc.plat.web')}</button>
            <button type="button" class="calc-btn" data-value="ios">{t('calc.plat.ios')}</button>
            <button type="button" class="calc-btn" data-value="android">{t('calc.plat.android')}</button>
            <button type="button" class="calc-btn" data-value="cross">{t('calc.plat.cross')}</button>
          </div>
        </div>

        <!-- Timeline -->
        <div class="space-y-5">
          <div class="flex justify-between items-center pl-1 pr-1">
            <label class="text-sm font-medium text-white/50 uppercase tracking-widest">{t('calc.timeline')}</label>
            <span id="timeline-display" class="bg-white/10 px-3 py-1 rounded-full text-sm font-semibold text-white">3 {t('calc.months')}</span>
          </div>
          <div class="relative pt-2 pb-6">
              <input type="range" min="1" max="12" value="3" id="calc-timeline">
              <div class="absolute left-0 right-0 flex justify-between text-[11px] font-medium text-white/40 mt-3 uppercase tracking-wider">
                  <span>1 {t('calc.month')}</span>
                  <span>12 {t('calc.months')}</span>
              </div>
          </div>
        </div>
      </div>

      <!-- Right: Output Section (Darker Inner Card) -->
      <div class="w-full lg:w-[460px] bg-black/40 p-8 sm:p-12 flex flex-col justify-center border-t lg:border-t-0 lg:border-l border-white/[0.08]">
        
        <div class="space-y-10" id="calc-results-container">
          <!-- Price Output -->
          <div>
            <div class="text-sm font-medium text-white/50 uppercase tracking-widest mb-3">{t('calc.estTotal')}</div>
            <div class="flex items-baseline gap-2">
              <div class="text-[64px] leading-none font-bold tracking-tighter" id="calc-price">$5,000</div>
            </div>
            <div class="text-sm font-medium text-white/30 mt-3 flex items-center gap-2">
               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
               {t('calc.basedOn')}
            </div>
          </div>

          <!-- Divider -->
          <div class="w-full h-px bg-white/10"></div>

          <!-- Team Output -->
          <div>
            <div class="text-sm font-medium text-white/50 uppercase tracking-widest mb-4">{t('calc.reqDevs')}</div>
            <div class="flex items-center gap-4">
               <div class="text-[40px] leading-none font-semibold tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-white to-white/60" id="calc-devs">
                 2 {t('calc.devs')}
               </div>
            </div>
          </div>

        </div>

        <button class="w-full mt-12 py-4 rounded-full bg-white hover:bg-white/90 text-black font-semibold text-lg transition-all shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:shadow-[0_0_30px_rgba(255,255,255,0.3)] hover:scale-[1.02] active:scale-[0.98]">
          {t('calc.getQuote')}
        </button>
      </div>

    </div>
  </div>
</section>

