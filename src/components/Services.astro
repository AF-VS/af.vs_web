---
// src/components/Services.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { servicesData } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const trans = servicesData[lang];

const services = [
  {
    title: trans[0].title,
    items: trans[0].items,
    svg: `
      <g class="stroke-blue-500/30" stroke-width="1">
        <path stroke-dasharray="2 4" d="M0,20 L240,20 M0,60 L240,60 M0,100 L240,100 M0,140 L240,140 M0,180 L240,180 M20,0 L20,240 M60,0 L60,240 M100,0 L100,240 M140,0 L140,240 M180,0 L180,240 M220,0 L220,240"/>
        <circle cx="140" cy="100" r="60" fill="rgba(48,84,255,0.05)"/>
        <rect x="40" y="60" width="80" height="80" rx="8" class="fill-blue-500/10"/>
        <circle cx="140" cy="100" r="25" fill="none" class="stroke-blue-400/80" stroke-width="2"/>
        <path d="M125,100 L155,100 M140,85 L140,115" class="stroke-blue-400/80"/>
      </g>
    `
  },
  {
    title: trans[1].title,
    items: trans[1].items,
    svg: `
      <g class="stroke-blue-500/30" stroke-width="1">
        <path stroke-dasharray="2 4" d="M0,20 L240,20 M0,60 L240,60 M0,100 L240,100 M0,140 L240,140 M0,180 L240,180 M20,0 L20,240 M60,0 L60,240 M100,0 L100,240 M140,0 L140,240 M180,0 L180,240 M220,0 L220,240"/>
        <rect x="60" y="100" width="30" height="80" class="fill-blue-500/10 stroke-blue-500/30"/>
        <rect x="110" y="70" width="30" height="110" class="fill-blue-500/20 stroke-blue-500/40"/>
        <rect x="160" y="30" width="30" height="150" class="fill-blue-500/30 stroke-blue-500/50"/>
        <polyline points="20,150 75,90 125,55 175,20 220,35" fill="none" stroke-width="2.5" class="stroke-blue-400"/>
        <circle cx="175" cy="20" r="6" class="fill-blue-400"/>
      </g>
    `
  },
  {
    title: trans[2].title,
    items: trans[2].items,
    svg: `
      <g class="stroke-blue-500/30" stroke-width="1">
        <path stroke-dasharray="2 4" d="M0,20 L240,20 M0,60 L240,60 M0,100 L240,100 M0,140 L240,140 M0,180 L240,180 M20,0 L20,240 M60,0 L60,240 M100,0 L100,240 M140,0 L140,240 M180,0 L180,240 M220,0 L220,240"/>
        <line x1="60" y1="60" x2="180" y2="120" class="stroke-blue-500/40" stroke-width="2"/>
        <line x1="180" y1="60" x2="60" y2="120" class="stroke-blue-500/40" stroke-width="2"/>
        <circle cx="60" cy="60" r="12" class="fill-blue-500/10 stroke-blue-500"/>
        <circle cx="180" cy="60" r="18" class="fill-blue-500/30 stroke-blue-400"/>
        <circle cx="60" cy="120" r="10" class="fill-blue-500/10 stroke-blue-500/50"/>
        <circle cx="180" cy="120" r="14" class="fill-blue-500/20 stroke-blue-500/80"/>
        <circle cx="120" cy="90" r="24" class="fill-black stroke-blue-400" stroke-width="2"/>
        <circle cx="120" cy="90" r="8" class="fill-blue-400"/>
      </g>
    `
  },
  {
    title: trans[3].title,
    items: trans[3].items,
    svg: `
      <g class="stroke-blue-500/30" stroke-width="1">
        <path stroke-dasharray="2 4" d="M0,20 L240,20 M0,60 L240,60 M0,100 L240,100 M0,140 L240,140 M0,180 L240,180 M20,0 L20,240 M60,0 L60,240 M100,0 L100,240 M140,0 L140,240 M180,0 L180,240 M220,0 L220,240"/>
        <!-- Isometric planes -->
        <polygon points="90,40 210,40 150,100 30,100" class="fill-blue-500/5 stroke-blue-500/20"/>
        <polygon points="90,80 210,80 150,140 30,140" class="fill-blue-500/15 stroke-blue-500/40"/>
        <polygon points="120,60 180,60 150,90 90,90" class="fill-blue-400/30 stroke-blue-400" stroke-width="2"/>
        <circle cx="150" cy="75" r="4" class="fill-white"/>
      </g>
    `
  }
];
---

<section id="services" class="relative bg-black overflow-hidden text-white font-instrument-sans h-screen min-h-[700px] flex items-center justify-center snap-start snap-always">
  <!-- Crosshair pattern background -->
  <div class="absolute inset-0 pointer-events-none opacity-20" 
       style="background-image: radial-gradient(circle at center, rgba(48,84,255,0.4) 1px, transparent 1px); background-size: 40px 40px;">
  </div>

  <div class="max-w-[1200px] w-full mx-auto px-6 lg:px-8 relative z-10 pt-20 pb-10 flex flex-col items-center">
    <!-- Section Title -->
    <div class="text-center mb-10 service-element opacity-0 translate-y-8 transition-all duration-1000 ease-out">
      <h2 class="text-4xl sm:text-5xl lg:text-5xl font-semibold mb-4 bg-gradient-to-b from-white via-white to-[#b4c0ff] bg-clip-text text-transparent tracking-tighter">
        {t('services.title')}
      </h2>
      <p class="text-white/60 text-base md:text-lg max-w-xl mx-auto">{t('services.subtitle')}</p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-6 md:grid-rows-2 gap-4 lg:gap-6 w-full max-h-[calc(100vh-220px)] overflow-visible">
      {services.map((service, index) => {
        const bentoConfigs = [
          "md:col-span-4 md:row-span-2 min-h-[380px]", // 0: Large Main
          "md:col-span-2 md:row-span-1 min-h-[180px]", // 1: Compact Side Top
          "md:col-span-2 md:row-span-1 min-h-[180px]", // 2: Compact Side Bottom
          "md:col-span-6 md:row-span-1 min-h-[120px]"  // 3: Wide horizontal bottom
        ];
        
        const config = bentoConfigs[index] || "md:col-span-3";

        return (
          <div class={`service-element opacity-0 translate-y-8 transition-all duration-1000 ease-out flex flex-col relative overflow-hidden rounded-[32px] border border-white/5 bg-[#0a0f24]/40 backdrop-blur-xl group hover:border-[#3054ff]/40 hover:-translate-y-1 hover:shadow-[0_20px_40px_-15px_rgba(48,84,255,0.3)] ${config}`} style={`transition-delay: ${index * 150}ms`}>
            
            <!-- Dynamic Gloss Shader -->
            <div class="absolute inset-0 bg-gradient-to-br from-white/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-1000 pointer-events-none"></div>
            
            <!-- Animated Ambient Glow -->
            <div class="absolute -bottom-16 -right-16 w-48 h-48 bg-[#3054ff]/10 blur-[80px] rounded-full group-hover:bg-[#3054ff]/20 transition-all duration-1000 group-hover:scale-110 pointer-events-none"></div>

            <!-- Content Container -->
            <div class={`relative z-10 p-6 md:p-8 flex-1 flex flex-col ${index === 3 ? 'md:flex-row md:items-center md:justify-between' : ''}`}>
              <div>
                <div class="mb-3 flex items-center gap-3">
                  <span class="text-[#3054ff] font-mono text-[11px] tracking-widest opacity-60">0{index + 1}</span>
                  <div class="h-[1px] w-8 bg-gradient-to-r from-[#3054ff] to-transparent"></div>
                </div>
                
                <h3 class={`${index === 0 ? 'text-[28px]' : 'text-[20px]'} font-bold tracking-tight mb-3 font-instrument-sans text-white group-hover:text-[#b4c0ff] transition-colors duration-500`}>
                  {service.title}
                </h3>

                <ul class={`${index === 3 ? 'flex flex-wrap gap-x-6 gap-y-1' : 'space-y-2'}`}>
                  {service.items.map(item => (
                    <li class="flex items-center gap-2 text-white/70 text-[14px] md:text-[15px] group/item">
                      <div class="w-1 h-1 rounded-full bg-[#3054ff]/40 group-hover/item:bg-[#3054ff] transition-colors"></div>
                      <span class="group-hover/item:text-white transition-colors cursor-default">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Decorative Visual -->
            {index !== 1 && index !== 2 && (
              <div class={`absolute bottom-0 right-0 ${index === 0 ? 'w-[220px] h-[180px]' : 'w-[140px] h-[100px]'} opacity-20 group-hover:opacity-60 transition-all duration-1000 group-hover:scale-105 overflow-hidden pointer-events-none`}>
                <svg width="100%" height="100%" viewBox="0 0 240 200" fill="none" class="absolute bottom-[-10px] right-[-10px]">
                  <Fragment set:html={service.svg} />
                </svg>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>

<script>
  const setupAnimations = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          observer.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      threshold: 0.1
    });

    document.querySelectorAll('.service-element').forEach(el => {
      observer.observe(el);
    });
  };

  setupAnimations();
</script>
