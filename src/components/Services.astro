---

<section id="services" class="relative py-32 bg-black overflow-hidden text-white font-instrument-sans min-h-screen">
  <!-- Crosshair pattern background similar to the second screenshot -->
  <div class="absolute inset-0 pointer-events-none opacity-20" 
       style="background-image: radial-gradient(circle at center, rgba(48,84,255,0.4) 1px, transparent 1px); background-size: 40px 40px;">
  </div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
    <!-- Section Title -->
    <div class="text-center mb-16 service-element opacity-0 translate-y-8 transition-all duration-1000 ease-out">
      <h2 class="text-4xl md:text-5xl font-instrument-sans font-medium tracking-tight">
        Services we provide
      </h2>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {services.map((service, index) => (
        <div class="service-element opacity-0 translate-y-8 transition-all duration-1000 ease-out flex flex-col relative overflow-hidden rounded-[32px] border border-white/5 bg-[#0a0f24]/50 backdrop-blur-md min-h-[440px] group hover:border-[#3054ff]/30 hover:-translate-y-2 hover:shadow-[0_8px_32px_-8px_rgba(48,84,255,0.25)]" style={`transition-delay: ${index * 150}ms`}>
          
          <!-- Inner Glow background -->
          <div class="absolute inset-0 bg-gradient-to-br from-[#3054ff]/5 to-transparent opacity-50 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
          
          <!-- Stronger localized glow at bottom right -->
          <div class="absolute -bottom-32 -right-32 w-80 h-80 bg-[#3054ff]/20 blur-[80px] rounded-full group-hover:bg-[#3054ff]/30 transition-colors duration-700 pointer-events-none"></div>

          <!-- Content -->
          <div class="relative z-10 p-10 flex-1 flex flex-col">
            <h3 class="text-[28px] font-bold tracking-tight mb-8 font-instrument-sans text-white">
              {service.title}
            </h3>

            <ul class="space-y-4">
              {service.items.map(item => (
                <li class="flex items-start gap-4 text-white/80 text-lg group/item">
                  <div class="mt-2 w-1.5 h-1.5 rounded-full bg-[#3054ff] shadow-[0_0_10px_rgba(48,84,255,0.8)] group-hover/item:scale-150 transition-transform"></div>
                  <span class="group-hover/item:text-white transition-colors">{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Decorative Geometric SVG Graphic -->
          <div class="absolute bottom-0 right-0 w-[240px] h-[200px] opacity-40 group-hover:opacity-100 transition-opacity duration-700 overflow-hidden pointer-events-none">
            <svg width="240" height="200" viewBox="0 0 240 200" fill="none" class="absolute bottom-[-20px] right-[-20px]">
              <Fragment set:html={service.svg} />
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Simple intersection observer for fade-in animations
  const setupAnimations = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          observer.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    });

    document.querySelectorAll('.service-element').forEach(el => {
      observer.observe(el);
    });
  };

  // Run on load
  setupAnimations();
</script>
