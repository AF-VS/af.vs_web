---
// src/components/Portfolio.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { portfolioData } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const trans = portfolioData[lang];

const projects = [
  { 
    id: 'memolink', 
    name: trans[0].name, 
    type: trans[0].type, 
    subtitle: trans[0].subtitle,
    images: { web: '/portfolio/memolink_web.png', mob: '/portfolio/memolink_mob.jpg' },
    video: '/portfolio/memolink.mp4',
    color: '#6366f1' // Indigo
  },
  { 
    id: 'pandev', 
    name: trans[1].name, 
    type: trans[1].type, 
    subtitle: trans[1].subtitle,
    images: { web: '/portfolio/pandev_web.png' },
    video: '/portfolio/pandev.mp4',
    color: '#0ea5e9' // Sky Blue
  },
  { 
    id: 'neva', 
    name: trans[2].name, 
    type: trans[2].type, 
    subtitle: trans[2].subtitle,
    images: { web: '/portfolio/neva_web.png', mob: '/portfolio/neva_mob.jpg' },
    color: '#10b981' // Emerald
  },
  { 
    id: 'hrms', 
    name: trans[3].name, 
    type: trans[3].type, 
    subtitle: trans[3].subtitle,
    images: { web: '/portfolio/hrms_web.jpg', mob: '/portfolio/hrms_mob.jpg' },
    color: '#f43f5e' // Rose
  }
];
---

<section id="cases" class="relative py-20 md:py-32 min-h-[100dvh] w-full flex flex-col justify-center bg-[#050505] overflow-hidden font-instrument-sans border-t border-white/5 cursor-default transition-colors duration-[1500ms] snap-start snap-always">
  <!-- Global Spotlight Beam (Concept 2, no clipping) -->
  <div 
    id="dynamic-spotlight" 
    class="absolute top-[-10%] md:top-[-25%] left-0 w-[500px] md:w-[800px] h-[800px] md:h-[1200px] rounded-full blur-[100px] md:blur-[140px] mix-blend-screen pointer-events-none opacity-0 transition-all duration-1000 ease-out z-0"
    style="background-color: transparent; transform: translate3d(calc(50vw - 50%), 0, 0);"
  ></div>

  <!-- Custom Drag Cursor (Desktop Only) -->
  <div id="drag-cursor" class="fixed top-0 left-0 pointer-events-none z-[100] flex items-center justify-center w-24 h-24 rounded-full bg-white text-black font-bold text-[10px] tracking-[0.2em] opacity-0 transition-opacity duration-300 hidden md:flex mix-blend-screen mix-blend-mode-difference" style="transform: translate3d(-100px, -100px, 0);">
    DRAG
  </div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-8 relative z-10 w-full flex flex-row items-center justify-between gap-4 md:gap-12 mb-10 md:mb-16">
    <!-- Section Title -->
    <div class="portfolio-animate opacity-0 translate-y-8 transition-all duration-1000 ease-out flex-1">
      <h2 class="text-3xl md:text-5xl lg:text-5xl font-bold tracking-tighter text-white mb-2 md:mb-4 uppercase leading-tight">
        {t('portfolio.title')}
      </h2>
      <p class="text-white/50 text-base md:text-xl font-medium max-w-[80%] md:max-w-none">{t('portfolio.subtitle')}</p>
    </div>

    <!-- Navigation Arrows -->
    <div class="flex shrink-0 gap-2 md:gap-3 portfolio-animate opacity-0 translate-y-8 transition-all duration-1000 ease-out" style="transition-delay: 200ms;">
      <button id="prev-btn" aria-label="Previous project" class="magnetic-btn w-12 h-12 rounded-full border border-white/20 flex items-center justify-center text-white/50 hover:text-white hover:border-white/50 transition-colors z-20">
        <span class="pointer-events-none transition-transform duration-300 ease-out"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg></span>
      </button>
      <button id="next-btn" aria-label="Next project" class="magnetic-btn w-12 h-12 rounded-full border border-white/20 flex items-center justify-center text-white hover:text-white hover:border-white transition-colors z-20">
        <span class="pointer-events-none transition-transform duration-300 ease-out"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
      </button>
    </div>
  </div>

  <!-- Carousel Container -->
  <div id="portfolio-scroll" class="flex gap-6 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-16 px-6 md:px-[calc((100vw-1200px)/2+2rem)] w-full scroll-smooth">
    {projects.map((p, index) => (
      <div 
        class="portfolio-animate snap-center shrink-0 w-[85vw] sm:w-[500px] md:w-[600px] relative group/card flex flex-col transition-all duration-700 ease-out hover:z-20 dim-siblings"
        style={`transition-delay: ${index * 150}ms;`}
        data-color={p.color}
      >
        <!-- Actual Inner Card (Liquid Glass) -->
        <div 
          class="portfolio-card w-full min-h-[500px] md:min-h-[540px] h-auto rounded-[32px] md:rounded-[40px] border border-white/[0.08] relative overflow-hidden group flex flex-col justify-between bg-[#050505]/40 backdrop-blur-[60px] backdrop-saturate-[150%] shadow-[inset_0_1px_1px_rgba(255,255,255,0.15),0_10px_40px_rgba(0,0,0,0.5)] p-6 md:p-8 z-10"
        >
          <!-- Additional Glossy Overlay for Liquid Glass -->
          <div class="absolute inset-0 bg-gradient-to-br from-white/[0.05] via-transparent to-transparent pointer-events-none rounded-[32px] md:rounded-[40px]"></div>

          <!-- Images setup (Floating Interface without black bg) -->
          <div class="relative w-full aspect-[16/11] md:aspect-[16/10] flex items-center justify-center pointer-events-none mt-2 mb-4 shrink-0">
          <!-- Main Web Screenshot and Video Layer -->
          <div class={`relative w-[90%] h-[90%] transition-all duration-[800ms] cubic-bezier(0.16, 1, 0.3, 1) ${p.images.mob ? '-ml-6 md:-ml-10' : 'mx-auto'} group-hover:scale-[1.04] md:group-hover:scale-[1.06] group-hover:-translate-y-4 ${p.images.mob ? 'group-hover:translate-x-3 md:group-hover:translate-x-6' : ''}`}>
            <img 
              src={p.images.web} 
              alt={p.name} 
              class="w-full h-full object-cover object-top rounded-xl md:rounded-2xl border border-white/10" 
            />
            {p.video && (
              <video 
                src={p.video} 
                muted loop playsinline preload="auto"
                class="portfolio-video absolute inset-0 w-full h-full object-cover object-top rounded-xl md:rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-[800ms]"
              ></video>
            )}
          </div>
          
          <!-- Floating Mobile Screenshot if exists -->
          {p.images.mob && (
            <img 
              src={p.images.mob} 
              alt="Mobile View" 
              class="absolute right-[2%] md:right-[0%] bottom-[16%] md:bottom-[16%] w-[55px] md:w-[75px] rounded-[6px] md:rounded-[10px] border border-white/10 shadow-[0_10px_30px_rgba(0,0,0,0.6)] transform transition-all duration-[800ms] group-hover:-translate-y-6 group-hover:opacity-0 group-hover:scale-90 group-hover:pointer-events-none" 
            />
          )}
        </div>

        <!-- Structured Text Area (No Lines, Chips on Top, HStack) -->
        <div class="relative z-10 w-full flex flex-col mt-auto gap-8 md:gap-12 px-1 md:px-0 pb-1">
          <!-- Tags Row (Chips) -->
          <div class="reveal-item flex flex-wrap justify-center items-center gap-2 md:gap-3">
            <span class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/80 text-[10px] md:text-[11px] font-medium tracking-wide">
              {p.type.toUpperCase()}
            </span>
            <span class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/80 text-[10px] md:text-[11px] font-medium tracking-wide hidden sm:inline-block">
              {t('portfolio.type.design')}
            </span>
            <span class="px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-white/80 text-[10px] md:text-[11px] font-medium tracking-wide hidden lg:inline-block">
              {t('portfolio.type.strategy')}
            </span>
          </div>

          <!-- Title & Subtitle Row (HStack 35/65) -->
          <div class="flex flex-row items-start justify-between w-full h-[65px] md:h-[75px]">
            <h3 class="reveal-item text-[22px] sm:text-[28px] md:text-[34px] font-bold text-white tracking-tight leading-[1.05] w-[35%] shrink-0 text-center text-balance px-1 md:px-2 pt-1 md:pt-0">
              {p.name}
            </h3>
            
            <p class="reveal-item text-white/60 text-[12px] sm:text-[13px] md:text-[14px] leading-relaxed w-[65%] text-center text-balance px-1 md:px-2 mt-[2px] md:mt-[4px]">
              {p.subtitle}
            </p>
          </div>
        </div>
      </div>
      </div>
    ))}
    
    <!-- Empty padding element to ensure the last item can scroll to the center -->
    <div class="shrink-0 w-6 md:w-[calc((100vw-1200px)/2)]" aria-hidden="true"></div>
  </div>
</section>

<style>
  /* Sibling Dimming Effect (Spotlight Concept) */
  #portfolio-scroll:has(.group\/card:hover) .dim-siblings:not(:hover) {
    opacity: 0.35;
    transform: scale(0.98);
    filter: grayscale(60%);
  }

  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }

  /* Magnetic Button Reset transition when actively moving */
  .magnetic-btn {
    transition: transform 0.4s cubic-bezier(0.1, 0.8, 0.1, 1), background-color 0.3s, border-color 0.3s, color 0.3s;
  }
  .magnetic-btn.is-moving {
    transition: transform 0.1s linear, background-color 0.3s, border-color 0.3s, color 0.3s;
  }

  /* Staggered Text Reveal base styles */
  .portfolio-card .reveal-item {
    opacity: 0.1;
    transform: translateY(16px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .portfolio-card.is-active .reveal-item {
    opacity: 1;
    transform: translateY(0);
  }
  .portfolio-card.is-active .reveal-item:nth-child(1) { transition-delay: 150ms; }
  .portfolio-card.is-active .reveal-item:nth-child(2) { transition-delay: 300ms; }
  .portfolio-card.is-active .reveal-item:nth-child(3) { transition-delay: 450ms; }
</style>

<script>
  // Handle Carousel Scrolling
  const setupCarousel = () => {
    const container = document.getElementById('portfolio-scroll');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');

    if (prevBtn && nextBtn && container) {
      prevBtn.addEventListener('click', () => {
        const cardWidth = window.innerWidth >= 768 ? 624 : window.innerWidth * 0.85 + 24;
        container.scrollBy({ left: -cardWidth, behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        const cardWidth = window.innerWidth >= 768 ? 624 : window.innerWidth * 0.85 + 24;
        container.scrollBy({ left: cardWidth, behavior: 'smooth' });
      });
    }
  };

  // Setup scroll animations
  const setupPortfolioAnimations = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          observer.unobserve(entry.target);
        }
      });
    }, {
      root: null,
      rootMargin: '0px',
      threshold: 0.15
    });

    document.querySelectorAll('.portfolio-animate').forEach(el => {
      observer.observe(el);
    });
  };

  // Setup Video Hover
  const setupHoverVideos = () => {
    const cards = document.querySelectorAll('.group');
    cards.forEach(card => {
      const video = card.querySelector('.portfolio-video') as HTMLVideoElement;
      if (video) {
        card.addEventListener('mouseenter', () => {
          const playPromise = video.play();
          if (playPromise !== undefined) {
            playPromise.catch(error => console.log('Playback prevented', error));
          }
        });
        card.addEventListener('mouseleave', () => {
          // Short delay before pause so it fades out smoothly
          window.setTimeout(() => {
            if (!video.paused) {
              video.pause();
            }
          }, 500); 
        });
      }
    });
  };

  // Setup Magnetic Buttons
  const setupMagneticButtons = () => {
    const buttons = document.querySelectorAll('.magnetic-btn');
    buttons.forEach(btn => {
      const el = btn as HTMLElement;
      const icon = el.querySelector('span') as HTMLElement;
      
      el.addEventListener('mousemove', (e) => {
        const rect = el.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        el.classList.add('is-moving');
        el.style.transform = `translate(${x * 0.4}px, ${y * 0.4}px)`;
        if(icon) icon.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
      });
      
      el.addEventListener('mouseleave', () => {
        el.classList.remove('is-moving');
        el.style.transform = '';
        if(icon) icon.style.transform = '';
      });
    });
  };

  // Setup Global Spotlight & Reveal
  const setupAmbilightAndReveal = () => {
    // Detect which card is predominantly in the center for reveal text
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-active');
        } else {
          entry.target.classList.remove('is-active');
        }
      });
    }, {
      root: document.getElementById('portfolio-scroll'),
      rootMargin: '0px',
      threshold: 0.6
    });

    document.querySelectorAll('.portfolio-card').forEach(el => {
      observer.observe(el);
    });

    // Handle Spotlight Following Hover
    const spotlight = document.getElementById('dynamic-spotlight');
    const scrollContainer = document.getElementById('portfolio-scroll');
    const cards = document.querySelectorAll('.group\\/card');
    
    if(!spotlight || !scrollContainer) return;

    // Follow mouse enter on cards
    cards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        const color = card.getAttribute('data-color');
        if(color) {
          spotlight.style.backgroundColor = color;
          spotlight.style.opacity = '0.45'; // Intensity of global spotlight
        }
        
        // Calculate dynamic X position
        const updateSpotlightPosition = () => {
          const cardRect = card.getBoundingClientRect();
          const centerX = cardRect.left + (cardRect.width / 2);
          // Translate to center X minus half width of spotlight
          spotlight.style.transform = `translate3d(calc(${centerX}px - 50%), 0, 0)`;
        };
        
        // Update immediately on enter
        updateSpotlightPosition();
        
        // Update while scrolling to stick to card seamlessly
        scrollContainer.addEventListener('scroll', updateSpotlightPosition, { passive: true });
        
        // Clean up on leave
        card.addEventListener('mouseleave', () => {
          spotlight.style.opacity = '0';
          scrollContainer.removeEventListener('scroll', updateSpotlightPosition);
        }, { once: true });
      });
    });
  };

  // Run on load
  setupCarousel();
  setupPortfolioAnimations();
  setupHoverVideos();
  setupMagneticButtons();
  setupAmbilightAndReveal();
</script>
