---
// src/components/ui/Badge.astro
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="ds-badge">{label}</span>

<style>
  .ds-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    opacity: 0.6;
    letter-spacing: 0.15em;
    line-height: 1;
  }
</style>
