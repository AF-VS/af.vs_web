---
// src/components/ui/header.astro
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header
  id="main-header"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-500 pt-4 px-4 pointer-events-none text-white flex justify-center"
>
  <div
    id="header-container"
    class="mx-auto w-full flex items-center justify-between transition-all duration-500 rounded-full pointer-events-auto border border-transparent max-w-[1200px] h-24 px-4"
  >
    <!-- Logo -->
    <a
      href={lang === "en" ? "/" : "/ru/"}
      id="header-logo"
      class="text-2xl font-bold tracking-tighter z-50 relative font-instrument-sans transition-all duration-500"
      >AF.VS</a
    >

    <!-- Desktop Nav -->
    <nav
      class="hidden md:flex items-center gap-12 lg:gap-16 font-instrument-sans"
    >
      <a
        href="#services"
        class="text-white/80 hover:text-white transition-colors"
        >{t("nav.services")}</a
      >
      <a href="#cases" class="text-white/80 hover:text-white transition-colors"
        >{t("nav.cases")}</a
      >
      <a
        href="#calculator"
        class="text-white/80 hover:text-white transition-colors"
        >{t("nav.calculator")}</a
      >
    </nav>

    <!-- Language Toggle Desktop -->
    <div
      class="lang-toggle-container hidden md:flex relative items-center w-[84px] h-[40px] rounded-full border border-white/20 p-1 font-instrument-sans z-50 overflow-hidden"
    >
      <!-- Thumb -->
      <div
        class={`lang-thumb absolute top-1 left-1 w-[36px] h-[30px] rounded-full bg-[#161616] transition-transform duration-300 shadow-[0_2px_8px_rgba(0,0,0,0.8)] border border-white/5 ${
          lang === "en" ? "translate-x-0" : "translate-x-[40px]"
        }`}
      >
      </div>

      <!-- Labels -->
      <div class="relative z-10 flex w-full h-full">
        <a
          href="/"
          class={`flex-1 flex items-center justify-center text-[12px] font-medium tracking-wider transition-colors duration-300 ${
            lang === "en" ? "text-white" : "text-white/40 hover:text-white"
          }`}>EN</a
        >
        <a
          href="/ru/"
          class={`flex-1 flex items-center justify-center text-[12px] font-medium tracking-wider transition-colors duration-300 ${
            lang === "ru" ? "text-white" : "text-white/40 hover:text-white"
          }`}>RU</a
        >
      </div>
    </div>

    <!-- Mobile Menu Toggle Button -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden z-50 relative p-2 text-white"
      aria-label="Toggle Menu"
    >
      <!-- Hamburger Icon -->
      <svg
        id="icon-menu"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="block transition-transform duration-300"
      >
        <line x1="4" x2="20" y1="12" y2="12"></line><line
          x1="4"
          x2="20"
          y1="6"
          y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line>
      </svg>
      <!-- Close Icon -->
      <svg
        id="icon-close"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden transition-transform duration-300"
      >
        <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Backdrop/Container -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-black/95 backdrop-blur-md opacity-0 pointer-events-none flex flex-col justify-center items-center transition-all duration-300 md:hidden z-40"
  >
    <nav
      class="flex flex-col items-center gap-8 font-instrument-sans text-3xl pointer-events-auto"
    >
      <a
        href="#services"
        class="mobile-link text-white/80 hover:text-white transition-colors"
        >{t("nav.services")}</a
      >
      <a
        href="#cases"
        class="mobile-link text-white/80 hover:text-white transition-colors"
        >{t("nav.cases")}</a
      >
      <a
        href="#calculator"
        class="mobile-link text-white/80 hover:text-white transition-colors"
        >{t("nav.calculator")}</a
      >

      <!-- Language Toggle Mobile -->
      <div
        class="lang-toggle-container flex relative items-center w-[120px] h-[52px] rounded-full border border-white/20 p-1.5 font-instrument-sans z-50 mt-8 mx-auto"
      >
        <!-- Thumb -->
        <div
          class={`lang-thumb absolute top-[6px] left-[6px] w-[52px] h-[38px] rounded-full bg-[#161616] transition-transform duration-300 shadow-[0_2px_8px_rgba(0,0,0,0.8)] border border-white/5 ${
            lang === "en" ? "translate-x-0" : "translate-x-[54px]"
          }`}
        >
        </div>

        <!-- Labels -->
        <div class="relative z-10 flex w-full h-full">
          <a
            href="/"
            class={`flex-1 flex items-center justify-center text-[16px] font-medium tracking-wider transition-colors duration-300 ${
              lang === "en" ? "text-white" : "text-white/40 hover:text-white"
            }`}>EN</a
          >
          <a
            href="/ru/"
            class={`flex-1 flex items-center justify-center text-[16px] font-medium tracking-wider transition-colors duration-300 ${
              lang === "ru" ? "text-white" : "text-white/40 hover:text-white"
            }`}>RU</a
          >
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  // Ensure the script runs on initial load and after view transitions (if Astro's ViewTransitions are later used)
  function initHeader() {
    const headerContainer = document.getElementById("header-container");
    const toggleBtn = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");
    const mobileLinks = document.querySelectorAll(".mobile-link");
    const logo = document.getElementById("header-logo");
    let isMenuOpen = false;

    if (!headerContainer || !toggleBtn) return;

    // Handle scroll for sticky header blur+bg
    const handleScroll = () => {
      if (window.scrollY > 20) {
        headerContainer.classList.add(
          "bg-zinc-950/80",
          "backdrop-blur-md",
          "border-white/10",
          "max-w-4xl",
          "h-16",
          "px-6",
        );
        headerContainer.classList.remove(
          "border-transparent",
          "max-w-6xl",
          "h-24",
          "px-4",
        );
        logo?.classList.add("text-xl");
        logo?.classList.remove("text-2xl");
      } else {
        headerContainer.classList.remove(
          "bg-zinc-950/80",
          "backdrop-blur-md",
          "border-white/10",
          "max-w-4xl",
          "h-16",
          "px-6",
        );
        headerContainer.classList.add(
          "border-transparent",
          "max-w-6xl",
          "h-24",
          "px-4",
        );
        logo?.classList.remove("text-xl");
        logo?.classList.add("text-2xl");
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll(); // Check initial scroll position

    // Handle mobile menu toggle
    function toggleMenu() {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        menu?.classList.remove("opacity-0", "pointer-events-none");
        menu?.classList.add("opacity-100", "pointer-events-auto");

        iconMenu?.classList.add("hidden");
        iconMenu?.classList.remove("block");
        iconClose?.classList.add("block");
        iconClose?.classList.remove("hidden");

        // Disable body scroll
        document.body.style.overflow = "hidden";
      } else {
        menu?.classList.remove("opacity-100", "pointer-events-auto");
        menu?.classList.add("opacity-0", "pointer-events-none");

        iconClose?.classList.add("hidden");
        iconClose?.classList.remove("block");
        iconMenu?.classList.add("block");
        iconMenu?.classList.remove("hidden");

        // Enable body scroll
        document.body.style.overflow = "";
      }
    }

    // Assign click listener
    toggleBtn.addEventListener("click", toggleMenu);

    // Close menu when clicking a link
    mobileLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (isMenuOpen) toggleMenu();
      });
    });

    // Language Toggle Animation
    const toggleContainers = document.querySelectorAll(
      ".lang-toggle-container",
    );
    toggleContainers.forEach((container) => {
      const links = container.querySelectorAll("a");
      const thumb = container.querySelector(".lang-thumb");
      if (!thumb) return;

      // Determine if this is the mobile container based on width class
      const isMobile = container.classList.contains("w-[120px]");

      links.forEach((link) => {
        link.addEventListener("click", (e) => {
          const href = link.getAttribute("href");

          // Skip animation if already active
          if (link.pathname === window.location.pathname) {
            e.preventDefault();
            return;
          }

          e.preventDefault();
          if (!href) return;

          const isRu = href === "/ru/";

          // Reset tailwind toggle classes
          thumb.classList.remove(
            "translate-x-0",
            "translate-x-[40px]",
            "translate-x-[54px]",
          );

          // Apply new translation class
          if (isRu) {
            thumb.classList.add(
              isMobile ? "translate-x-[54px]" : "translate-x-[40px]",
            );
          } else {
            thumb.classList.add("translate-x-0");
          }

          // Wait for transition to finish before navigating
          setTimeout(() => {
            window.location.href = href;
          }, 300);
        });
      });
    });
  }

  // Run initialization
  initHeader();
</script>
