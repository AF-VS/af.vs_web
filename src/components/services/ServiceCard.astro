---
import { Image } from 'astro:assets';
import Chip from '../ui/Chip.astro';

interface Props {
  title: string;
  description: string;
  tags: readonly string[];
  image: ImageMetadata;
  class?: string;
}

const { title, description, tags, image, class: className } = Astro.props;
---

<article class:list={['card', className]} data-glow-card data-animate>
  <div class="card__img">
    <Image src={image} alt="" aria-hidden="true" loading="lazy" widths={[368, 502, 736, 1024]} sizes="(min-width: 2560px) 1024px, (min-width: 1920px) 736px, (min-width: 1248px) 502px, (min-width: 768px) 50vw, 100vw" />
  </div>

  <div class="card__body">
    <div class="card__text">
      <h3 class="card__title">{title}</h3>
      <p class="card__desc">{description}</p>
    </div>
    <div class="card__tags">
      {tags.map((t) => <Chip label={t} />)}
    </div>
  </div>
</article>

<style>
  .card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: var(--surface-card-glass);
    /* Blur cost scales quadratically with radius. 10px keeps the glass
       read intact over the dark background at ~6× cheaper per scroll frame. */
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: none;
    border-radius: var(--radius-card);
    padding: var(--spacing-card);
    /* Skip paint/layout work for cards outside the viewport.
       Reserves intrinsic size so layout doesn't jump. */
    content-visibility: auto;
    contain-intrinsic-size: 1px 360px;
    /* Isolate paint: a card's expensive backdrop-filter + blend-mode
       repaint no longer invalidates siblings.
       inline-size containment (via container-type) enables container queries
       so image intensity scales with card width on large displays. */
    contain: layout paint style;
    container-type: inline-size;

    /* Magic Bento glow driven by Services.astro mousemove controller */
    --glow-x: 50%;
    --glow-y: 50%;
    --glow-intensity: 0;
    --glow-radius: 320px;
    --glow-color: var(--primary-default-rgb);

    transition: box-shadow 0.4s ease;
    box-shadow:
      0 0 calc(48px * var(--glow-intensity))
        rgba(var(--glow-color), calc(0.22 * var(--glow-intensity))),
      0 0 calc(96px * var(--glow-intensity))
        rgba(var(--glow-color), calc(0.1 * var(--glow-intensity)));
  }

  /* ── Gradient border (top-lit glass edge) ──── */
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      180deg,
      var(--border-glass-top) 0%,
      var(--border-glass-bottom) 100%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
    z-index: 2;
  }

  /* ── Border glow (Magic Bento) ───────────────── */
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 2px;
    background: radial-gradient(
      var(--glow-radius) circle at var(--glow-x) var(--glow-y),
      rgba(var(--glow-color), 0.9) 0%,
      rgba(var(--glow-color), 0.5) 30%,
      transparent 60%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    pointer-events: none;
    z-index: 3;
    /* Gate the whole mask-composite layer on intensity so the compositor
       skips it entirely when the glow is off (the common case during scroll). */
    opacity: var(--glow-intensity);
    mask-composite: exclude;
  }

  /* ── Image layer ─────────────────────────────── */
  .card__img {
    position: absolute;
    z-index: 0;
    top:     var(--img-top, auto);
    left:    var(--img-left, auto);
    right:   var(--img-right, auto);
    bottom:  var(--img-bottom, auto);
    width:   var(--img-width, auto);
    height:  var(--img-height, auto);
    translate: var(--img-translate, 0 0);
    pointer-events: none;
    user-select: none;
    mask-image: var(--img-mask, none);
    -webkit-mask-image: var(--img-mask, none);
  }

  .card__img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: var(--img-opacity, 0.5);
    rotate: var(--img-rotate, 0deg);
    mix-blend-mode: lighten;
    transition: opacity 0.4s ease;
  }

  /* ── Adaptive image intensity by card width ──
     Cards stay readable on small widths, image asserts itself on large ones
     (2K/4K displays where ambient card width grows).
     Thresholds account for content-box inline-size (container-type queries
     the inner width, after padding ≈ 16–40px on each side). */
  @container (min-width: 400px) {
    .card__img :global(img) { opacity: var(--img-opacity, 0.6); }
  }
  @container (min-width: 620px) {
    .card__img :global(img) { opacity: var(--img-opacity, 0.75); }
  }
  @container (min-width: 900px) {
    .card__img :global(img) { opacity: var(--img-opacity, 0.88); }
  }

  .card:hover .card__img :global(img) {
    opacity: 0.7;
  }

  /* ── Content layer ───────────────────────────── */
  .card__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-card);
    flex: 1;
    justify-content: flex-end;
  }

  .card__text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-text-gap);
  }

  .card__title {
    font-family: var(--font-body);
    font-size: var(--font-size-h4);
    font-weight: 600;
    line-height: var(--line-height-h4);
    letter-spacing: var(--letter-spacing-h4);
    color: var(--text-primary);
    margin: 0;
  }

  .card__desc {
    font-family: var(--font-body);
    font-size: var(--font-size-body);
    line-height: var(--line-height-body);
    color: var(--text-secondary);
    margin: 0;
    max-width: 40ch;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-tags-gap);
  }

  @media (max-width: 743px) {
    /* Give the image layer enough vertical room to actually read on phones.
       Without this, title + description + 2 chips collapse the card to
       ~240px and the absolutely-positioned image is barely visible. */
    .card {
      min-height: 360px;
    }

    .card__tags {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-tags-gap);
    }

    /* Chips must fit the single grid cell cleanly. Override the default
       `white-space: nowrap` from Chip.astro: allow label wrapping / ellipsis
       so no chip overflows its 2-col cell on the smallest screens. */
    .card__tags :global(.chip) {
      justify-content: center;
      text-align: center;
      min-width: 0;
      max-width: 100%;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* Keep the chip group to a single 2-col row on mobile — long tag lists
       (build, growth) are truncated after the first two for a compact card. */
    .card__tags :global(.chip:nth-child(n + 3)) {
      display: none;
    }
  }
</style>
