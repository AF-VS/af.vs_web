---
import { Image } from 'astro:assets';
import Chip from './Chip.astro';

interface Props {
  title: string;
  description: string;
  tags: ReadonlyArray<string>;
  image: ImageMetadata;
  class?: string;
}

const { title, description, tags, image, class: className } = Astro.props;
---

<article class:list={['card', className]} data-glow-card data-animate>
  <div class="card__img">
    <Image src={image} alt="" loading="lazy" widths={[368, 502, 736]} sizes="(min-width: 1248px) 502px, (min-width: 768px) 50vw, 100vw" />
  </div>

  <div class="card__body">
    <div class="card__text">
      <h3 class="card__title">{title}</h3>
      <p class="card__desc">{description}</p>
    </div>
    <div class="card__tags">
      {tags.map((t) => <Chip label={t} />)}
    </div>
  </div>
</article>

<style>
  .card {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: rgba(10, 22, 38, 0.55);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: none;
    border-radius: var(--radius-card);
    padding: var(--spacing-card);

    /* Magic Bento glow driven by Services.astro mousemove controller */
    --glow-x: 50%;
    --glow-y: 50%;
    --glow-intensity: 0;
    --glow-radius: 320px;
    --glow-color: 21, 142, 242; /* --primary-default */

    transition: box-shadow 0.4s ease;
    box-shadow:
      0 0 calc(48px * var(--glow-intensity))
        rgba(var(--glow-color), calc(0.22 * var(--glow-intensity))),
      0 0 calc(96px * var(--glow-intensity))
        rgba(var(--glow-color), calc(0.1 * var(--glow-intensity)));
  }

  /* ── Gradient border (top-lit glass edge) ──── */
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.14) 0%,
      rgba(255, 255, 255, 0.03) 100%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
    z-index: 2;
  }

  /* ── Border glow (Magic Bento) ───────────────── */
  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 2px;
    background: radial-gradient(
      var(--glow-radius) circle at var(--glow-x) var(--glow-y),
      rgba(var(--glow-color), calc(var(--glow-intensity) * 0.9)) 0%,
      rgba(var(--glow-color), calc(var(--glow-intensity) * 0.5)) 30%,
      transparent 60%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    pointer-events: none;
    z-index: 3;
  }

  .card:hover .card__img :global(img) {
    opacity: 1;
  }

  /* ── Image layer ─────────────────────────────── */
  .card__img {
    position: absolute;
    z-index: 0;
    top:     var(--img-top, auto);
    left:    var(--img-left, auto);
    right:   var(--img-right, auto);
    bottom:  var(--img-bottom, auto);
    width:   var(--img-width, auto);
    height:  var(--img-height, auto);
    translate: var(--img-translate, 0 0);
    pointer-events: none;
    user-select: none;
    mask-image: var(--img-mask, none);
    -webkit-mask-image: var(--img-mask, none);
  }

  .card__img :global(img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.7;
    rotate: var(--img-rotate, 0deg);
    mix-blend-mode: lighten;
    transition: opacity 0.4s ease;
  }

  /* ── Content layer ───────────────────────────── */
  .card__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-card);
    flex: 1;
    justify-content: flex-end;
  }

  .card__text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-text-gap);
  }

  .card__title {
    font-family: var(--font-body);
    font-size: var(--font-size-h4);
    font-weight: 600;
    line-height: var(--line-height-h4);
    letter-spacing: var(--letter-spacing-h4);
    color: var(--text-primary);
    margin: 0;
  }

  .card__desc {
    font-family: var(--font-body);
    font-size: var(--font-size-body);
    line-height: var(--line-height-body);
    color: var(--text-secondary);
    margin: 0;
    max-width: 40ch;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-tags-gap);
  }
</style>
