---
import type { Dict } from '../../i18n/en';
import ServiceCard from './ServiceCard.astro';

import codePng from '../../assets/services/code.png';
import robotPng from '../../assets/services/robot.png';
import compassPng from '../../assets/services/compass.png';
import handsPng from '../../assets/services/hands.png';

interface Props {
  dict: Dict;
}

const { dict } = Astro.props;
const s = dict.services;
---

<section id="services" class="services section-viewport">
  <div class="grid">
    <ServiceCard
      class="card--build"
      title={s.build.title}
      description={s.build.description}
      tags={s.build.tags}
      image={codePng}
    />

    <ServiceCard
      class="card--ai"
      title={s.ai.title}
      description={s.ai.description}
      tags={s.ai.tags}
      image={robotPng}
    />

    <ServiceCard
      class="card--advisory"
      title={s.advisory.title}
      description={s.advisory.description}
      tags={s.advisory.tags}
      image={compassPng}
    />

    <ServiceCard
      class="card--growth"
      title={s.growth.title}
      description={s.growth.description}
      tags={s.growth.tags}
      image={handsPng}
    />
  </div>
</section>

<style>
  .services {
    padding: var(--spacing-section) 0;
    box-sizing: border-box;
  }

  .grid {
    display: grid;
    gap: var(--spacing-grid);
    grid-template-columns: 1fr;
    height: 100%;
    padding-inline: var(--container-padding);
  }

  /* ── Card image positioning (% values adapt to card size) ── */
  .grid :global(.card--build) {
    --img-right: 0;
    --img-top: 50%;
    --img-width: 64%;
    --img-height: 84%;
    --img-translate: 0 -50%;
    --img-mask: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.4) 25%, black 55%);
  }

  .grid :global(.card--ai) {
    --img-left: 64%;
    --img-top: 27%;
    --img-width: 77%;
    --img-translate: -50% -50%;
    --img-rotate: -170.43deg;
  }

  .grid :global(.card--advisory) {
    --img-left: 57%;
    --img-top: 19%;
    --img-width: 95%;
    --img-translate: -50% -50%;
  }

  .grid :global(.card--growth) {
    --img-left: 50%;
    --img-top: 44%;
    --img-width: 100%;
    --img-translate: -50% -50%;
  }

  @media (min-width: 744px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .grid :global(.card--build) {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 1248px) {
    .grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(2, minmax(clamp(280px, 25vw, 420px), 1fr));
    }

    .grid :global(.card--build) {
      grid-column: 1 / 3;
    }

    .grid :global(.card--growth) {
      grid-column: 3;
      grid-row: 1 / 3;
    }

    .grid :global(.card--ai) {
      grid-column: 1;
      grid-row: 2;
    }

    .grid :global(.card--advisory) {
      grid-column: 2;
      grid-row: 2;
    }
  }
</style>
