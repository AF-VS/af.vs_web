---
import "../styles/global.css";
import Ambient from "../components/chrome/Ambient/Ambient.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import interLatinWoff2 from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import interCyrillicWoff2 from "@fontsource-variable/inter/files/inter-cyrillic-wght-normal.woff2?url";
import { getDict } from "../i18n";

type Locale = "en" | "ru" | "uz";

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  locale: Locale;
  canonical?: string;
}

const {
  title,
  description,
  locale,
  ogTitle = title,
  ogDescription = description,
  ogImage = `/og/${locale}.png`,
  canonical,
} = Astro.props;

const dict = getDict(locale);

const siteUrl = "https://afvs.dev";
const pathname = Astro.url.pathname;
const pathWithoutLocale = pathname.replace(/^\/(ru|uz)(?=\/|$)/, "") || "/";
const canonicalHref = canonical ?? `${siteUrl}${pathname}`;

function altHref(l: Locale): string {
  if (l === "en") return `${siteUrl}${pathWithoutLocale}`;
  const suffix = pathWithoutLocale === "/" ? "/" : pathWithoutLocale;
  return `${siteUrl}/${l}${suffix}`;
}

const orgId = `${siteUrl}/#organization`;
const websiteId = `${siteUrl}/#website`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": orgId,
      name: "AF Venture Studio",
      alternateName: ["AFVS", "AF Venture", "afvs"],
      url: siteUrl,
      logo: {
        "@type": "ImageObject",
        url: `${siteUrl}/apple-touch-icon.png`,
        width: 180,
        height: 180,
      },
      description,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Tashkent",
        addressCountry: "UZ",
      },
      sameAs: [
        "https://www.linkedin.com/company/af-venture-studio/",
        "https://www.instagram.com/afventurestudio/",
        "https://t.me/afvsdev",
        "https://clutch.co/profile/af-venture-studio",
      ],
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: siteUrl,
      name: "AF Venture Studio",
      description,
      publisher: { "@id": orgId },
      inLanguage: ["en", "ru", "uz"],
    },
  ],
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="preload" href={interLatinWoff2} as="font" type="font/woff2" crossorigin />
    {locale === "ru" && (
      <link rel="preload" href={interCyrillicWoff2} as="font" type="font/woff2" crossorigin />
    )}
    <script is:inline>document.documentElement.classList.add("js");</script>
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#101b2c" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" hreflang="en" href={altHref("en")} />
    <link rel="alternate" hreflang="ru" href={altHref("ru")} />
    <link rel="alternate" hreflang="uz" href={altHref("uz")} />
    <link rel="alternate" hreflang="x-default" href={altHref("en")} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AF Venture Studio" />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogTitle} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:locale" content={locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:image:alt" content={ogTitle} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">{dict.a11y.skipToContent}</a>
    <Ambient />
    <slot />
    <Analytics />
    <SpeedInsights />
    <script>
      import("../scripts/reveal").then(({ initReveal }) => initReveal());
    </script>
  </body>
</html>
